# Copiar a .env: copy .env.example .env (Windows) o cp .env.example .env

WEB_PORT=18080
APP_URL=http://localhost:18080

MYSQL_DATABASE=app_db
MYSQL_USER=app_user
MYSQL_PASSWORD=app_password
MYSQL_ROOT_PASSWORD=rootpassword
# MYSQL_PORT=3306  # usar con docker-compose.db-port.yml

JWT_SECRET=super_secret_key_123
JWT_TTL=3600
APP_ENV=development
APP_DEBUG=true

# Vite dev (npm run dev en frontend/)
VITE_DEV_API_PROXY=http://127.0.0.1:18080

# phpMyAdmin opcional (docker-compose.phpmyadmin.yml)
PMA_PORT=8081
